   "source": [
    "# Visualizaciones del análisis FAOSTAT\n",
    "\n",
    "Este notebook contiene los gráficos generados a partir de los indicadores del dominio CoAHD para Colombia (2024)."
   ]
  },
{
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
  "import matplotlib.pyplot as plt\n",
  "\n",
  "# Datos del gráfico\n",
  "categorias = ['CoHD (LCU)', 'CoHD (PPP)']\n",
  "valores = [7561, 4.67]\n",
  "\n",
  "plt.figure(figsize=(8, 5))\n",
  "plt.bar(categorias, valores, color=['#4C72B0', '#55A868'])\n",
  "\n",
  "plt.title('Costo de una dieta saludable en Colombia (2024)')\n",
  "plt.ylabel('Valor')\n",
  "plt.xlabel('Indicador')\n",
  "\n",
  "# Mostrar valores encima de las barras\n",
  "for i, v in enumerate(valores):\n",
  "    plt.text(i, v + (v * 0.05), str(v), ha='center')\n",
  "\n",
  "plt.show()"
 ]
},

